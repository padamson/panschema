/output/
examples/**/output/
examples/**/docs/
examples/**/index.html
examples/**/panschema_viz.*
**/*.rs.bk
.DS_Store
typos.toml
.env

# cargo-mutants output (local runs leave these; CI uploads as artifact)
/mutants.out/
/mutants.out.old/
